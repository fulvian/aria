# ARIA Environment Template
# Copy this file to .env and fill in your values
# NEVER commit the actual .env file with real secrets

# === ARIA Paths (usually correct, no need to change) ===
ARIA_HOME=/home/fulvio/coding/aria
ARIA_RUNTIME=/home/fulvio/coding/aria/.aria/runtime
ARIA_CREDENTIALS=/home/fulvio/coding/aria/.aria/credentials

# === KiloCode Isolation (do not modify) ===
KILOCODE_CONFIG_DIR=/home/fulvio/coding/aria/.aria/kilocode
KILOCODE_STATE_DIR=/home/fulvio/coding/aria/.aria/kilocode/sessions

# === Operational Settings ===
ARIA_LOG_LEVEL=INFO
ARIA_TIMEZONE=Europe/Rome
ARIA_LOCALE=it_IT.UTF-8
# Quiet hours: no proactive notifications during this time range
ARIA_QUIET_HOURS=22:00-07:00

# === Telegram Configuration ===
# Comma-separated list of authorized Telegram user IDs
ARIA_TELEGRAM_WHITELIST=123456789

# === SOPS Configuration ===
# Age key file location (default, usually correct)
SOPS_AGE_KEY_FILE=~/.config/sops/age/keys.txt

# === Provider API Keys ===
# Add your API keys here. They will be encrypted with SOPS+age.
# DO NOT add real keys to this file - use: sops .aria/credentials/secrets/api-keys.enc.yaml

# Example (commented out):
# TAVILY_API_KEY=tvly-your-key-here
# BRAVE_API_KEY=your-brave-key-here
# FIRECRAWL_API_KEY=your-firecrawl-key-here
# EXA_API_KEY=your-exa-key-here

# === Google Workspace OAuth ===
# Set up via scripts/oauth_first_setup.py
# GOOGLE_OAUTH_CLIENT_ID=your-client-id.apps.googleusercontent.com
# GOOGLE_OAUTH_REDIRECT_URI=http://localhost:8080/callback

# === GitHub Token ===
# GITHUB_PERSONAL_ACCESS_TOKEN=ghp_your_token_here

# === OpenAI (for Whisper API, optional) ===
# OPENAI_API_KEY=sk-your-key-here
