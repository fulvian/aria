# ARIA Environment Template
# Copy this file to .env and fill in your values
# NEVER commit the actual .env file with real secrets

# === ARIA Paths (usually correct, no need to change) ===
ARIA_HOME=/home/fulvio/coding/aria
ARIA_RUNTIME=/home/fulvio/coding/aria/.aria/runtime
ARIA_CREDENTIALS=/home/fulvio/coding/aria/.aria/credentials

# === KiloCode Isolation (do not modify) ===
KILOCODE_CONFIG_DIR=/home/fulvio/coding/aria/.aria/kilocode
KILOCODE_STATE_DIR=/home/fulvio/coding/aria/.aria/kilocode/sessions

# === Operational Settings ===
ARIA_LOG_LEVEL=INFO
ARIA_TIMEZONE=Europe/Rome
ARIA_LOCALE=it_IT.UTF-8
# Quiet hours: no proactive notifications during this time range
ARIA_QUIET_HOURS=22:00-07:00

# === Telegram Configuration ===
# Comma-separated list of authorized Telegram user IDs
ARIA_TELEGRAM_WHITELIST=123456789

# === SOPS Configuration ===
# Age key file location (default, usually correct)
SOPS_AGE_KEY_FILE=~/.config/sops/age/keys.txt

# === Provider API Keys (env fallback — primary: SOPS credential store) ===
# Primary key per provider for env fallback. Rotation system manages multiple keys

# === PubMed / NCBI (ottenere chiave gratuita) ===
# https://www.ncbi.nlm.nih.gov/account/settings/
# NCBI_API_KEY=  # opzionale, raccomandata (10 req/s vs 3)
# NCBI_ADMIN_EMAIL=fulviold@gmail.com
# UNPAYWALL_EMAIL=fulviold@gmail.com

# === Reddit OAuth (Phase 5, HITL gate) ===
# https://www.reddit.com/prefs/apps  (type: script)
# REDDIT_CLIENT_ID=
# REDDIT_CLIENT_SECRET=
# per provider via SOPS-encrypted api-keys.enc.yaml
# TAVILY_API_KEY=tvly-your-key-here
# BRAVE_API_KEY=BSA-your-key-here
# FIRECRAWL_API_KEY=fc-your-key-here
# FIRECRAWL_API_URL=https://api.firecrawl.dev
# EXA_API_KEY=your-exa-key-here
SEARXNG_SERVER_URL=http://127.0.0.1:8888

# === Google Workspace OAuth ===
# Client credentials per Google Cloud Console. Copia da token JSON esistente.
# GOOGLE_OAUTH_CLIENT_ID=your-client-id.apps.googleusercontent.com
# GOOGLE_OAUTH_CLIENT_SECRET=your-client-secret
# GOOGLE_OAUTH_REDIRECT_URI=http://127.0.0.1:8080/callback
# USER_GOOGLE_EMAIL=your.email@gmail.com
# GOOGLE_WORKSPACE_TOOLS=gmail drive calendar docs sheets slides
# OAUTHLIB_INSECURE_TRANSPORT=1 (required for local loopback OAuth)

# === GitHub Token ===
# GITHUB_PERSONAL_ACCESS_TOKEN=ghp_your_token_here

# === OpenAI (for Whisper API, optional) ===
# OPENAI_API_KEY=sk-your-key-here
