{
  "mcpServers": {
    "filesystem": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-filesystem", "/home/fulvio/coding/aria"],
      "disabled": false
    },
    "git": {
      "command": "uvx",
      "args": ["mcp-server-git", "--repository", "/home/fulvio/coding/aria"]
    },
    "github": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-github"],
      "env": {
        "GITHUB_PERSONAL_ACCESS_TOKEN": "${GITHUB_PERSONAL_ACCESS_TOKEN}"
      }
    },
    "sequential-thinking": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-sequential-thinking"]
    },
    "fetch": {
      "command": "uvx",
      "args": ["mcp-server-fetch"]
    },
    "aria-memory": {
      "command": "/home/fulvio/coding/aria/.venv/bin/python",
      "args": ["-m", "aria.memory.mcp_server"],
      "env": {
        "ARIA_HOME": "/home/fulvio/coding/aria"
      }
    },
    "tavily-mcp": {
      "command": "/home/fulvio/coding/aria/scripts/wrappers/tavily-wrapper.sh",
      "disabled": false,
      "timeout": 120000,
      "env": {
        "TAVILY_API_KEY": "${TAVILY_API_KEY}"
      },
      "_comment": "@phase1 provider integration - search agent dependency"
    },
    "firecrawl-mcp": {
      "command": "/home/fulvio/coding/aria/scripts/wrappers/firecrawl-wrapper.sh",
      "disabled": false,
      "timeout": 120000,
      "env": {
        "FIRECRAWL_API_KEY": "${FIRECRAWL_API_KEY}"
      },
      "_comment": "@phase1 provider integration - search agent dependency"
    },
    "brave-mcp": {
      "command": "npx",
      "args": ["-y", "@brave/brave-search-mcp-server"],
      "disabled": false,
      "timeout": 120000,
      "env": {
        "BRAVE_API_KEY": "${BRAVE_API_KEY_ACTIVE}"
      },
      "_comment": "@phase1 provider integration - search agent dependency"
    },
    "exa-script": {
      "command": "/home/fulvio/coding/aria/scripts/wrappers/exa-wrapper.sh",
      "disabled": false,
      "timeout": 120000,
      "env": {
        "EXA_API_KEY": "${EXA_API_KEY}"
      },
      "_comment": "@phase1 provider integration - search agent dependency"
    },
    "searxng-script": {
      "command": "/home/fulvio/coding/aria/scripts/wrappers/searxng-wrapper.sh",
      "disabled": false,
      "timeout": 120000,
      "env": {
        "SEARXNG_SERVER_URL": "${SEARXNG_SERVER_URL}",
        "SEARXNG_URL": "${SEARXNG_URL}"
      },
      "_comment": "@phase1 self-hosted metasearch dependency"
    },
    "google_workspace": {
      "command": "uvx",
      "args": [
        "workspace-mcp",
        "--tools",
        "docs",
        "sheets",
        "slides",
        "drive"
      ],
      "disabled": false,
      "env": {
        "GOOGLE_OAUTH_CLIENT_ID": "${GOOGLE_OAUTH_CLIENT_ID}",
        "GOOGLE_OAUTH_CLIENT_SECRET": "${GOOGLE_OAUTH_CLIENT_SECRET}",
        "GOOGLE_OAUTH_REDIRECT_URI": "http://127.0.0.1:8080/callback",
        "GOOGLE_OAUTH_USE_PKCE": "true",
        "OAUTHLIB_INSECURE_TRANSPORT": "1"
      },
      "_comment": "@phase1 write-enabled profile - tools: docs/sheets/slides/drive"
    }
  }
}
