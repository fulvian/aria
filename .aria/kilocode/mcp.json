{
  "mcpServers": {
    "filesystem": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-filesystem", "/home/fulvio/coding/aria"],
      "disabled": false
    },
    "git": {
      "command": "uvx",
      "args": ["mcp-server-git", "--repository", "/home/fulvio/coding/aria"]
    },
    "github": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-github"],
      "env": {
        "GITHUB_PERSONAL_ACCESS_TOKEN": "${GITHUB_PERSONAL_ACCESS_TOKEN}"
      }
    },
    "sequential-thinking": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-sequential-thinking"]
    },
    "fetch": {
      "command": "uvx",
      "args": ["mcp-server-fetch"]
    },
    "aria-memory": {
      "command": "/home/fulvio/coding/aria/.venv/bin/python",
      "args": ["-m", "aria.memory.mcp_server"],
      "env": {
        "ARIA_HOME": "/home/fulvio/coding/aria"
      }
    },
    "tavily-mcp": {
      "command": "/home/fulvio/coding/aria/scripts/wrappers/tavily-wrapper.sh",
      "disabled": false,
      "env": {
        "TAVILY_API_KEY": "${TAVILY_API_KEY}",
        "SOPS_AGE_KEY_FILE": "/home/fulvio/.config/sops/age/keys.txt",
        "ARIA_HOME": "/home/fulvio/coding/aria"
      }
    },

    "brave-mcp": {
      "command": "/home/fulvio/coding/aria/scripts/wrappers/brave-wrapper.sh",
      "disabled": false,
      "env": {
        "BRAVE_API_KEY": "${BRAVE_API_KEY}",
        "SOPS_AGE_KEY_FILE": "/home/fulvio/.config/sops/age/keys.txt",
        "ARIA_HOME": "/home/fulvio/coding/aria",
        "ARIA_CREDENTIALS": "/home/fulvio/coding/aria/.aria/credentials"
      }
    },
    "exa-script": {
      "command": "/home/fulvio/coding/aria/scripts/wrappers/exa-wrapper.sh",
      "disabled": false,
      "env": {
        "EXA_API_KEY": "${EXA_API_KEY}",
        "SOPS_AGE_KEY_FILE": "/home/fulvio/.config/sops/age/keys.txt",
        "ARIA_HOME": "/home/fulvio/coding/aria"
      }
    },
    "searxng-script": {
      "command": "/home/fulvio/coding/aria/scripts/wrappers/searxng-wrapper.sh",
      "disabled": false,
      "env": {
        "SEARXNG_SERVER_URL": "${SEARXNG_SERVER_URL}",
        "SEARXNG_URL": "${SEARXNG_URL}"
      }
    },
    "google_workspace": {
      "command": "/home/fulvio/coding/aria/scripts/wrappers/google-workspace-wrapper.sh",
      "disabled": false,
      "env": {
        "GOOGLE_OAUTH_CLIENT_ID": "${GOOGLE_OAUTH_CLIENT_ID}",
        "GOOGLE_OAUTH_CLIENT_SECRET": "${GOOGLE_OAUTH_CLIENT_SECRET}",
        "GOOGLE_OAUTH_REDIRECT_URI": "http://127.0.0.1:8080/callback",
        "GOOGLE_OAUTH_USE_PKCE": "true",
        "OAUTHLIB_INSECURE_TRANSPORT": "1",
        "USER_GOOGLE_EMAIL": "${USER_GOOGLE_EMAIL}",
        "GOOGLE_WORKSPACE_TOOLS": "gmail drive calendar docs sheets slides"
      },
      "_comment": "@phase2 single-user, gmail+calendar expanded — see docs/plans/rispristino_agenti_ricerca_google.md"
    },
    "playwright": {
      "command": "npx",
      "args": ["-y", "@executeautomation/playwright-mcp-server"],
      "disabled": true,
      "_comment": "@fase2"
    },
    "scientific-papers-mcp": {
      "command": "/home/fulvio/coding/aria/scripts/wrappers/scientific-papers-wrapper.sh",
      "disabled": false,
      "_comment": "@v2 Scientific Papers MCP (benedict2310/scientific-papers-mcp) — 6 sources including Europe PMC (PubMed content), arXiv, OpenAlex, keyless. Pubmed-MCP REMOVED 2026-04-30: scientific-papers-mcp covers PubMed via europepmc source; pubmed-mcp had startup failures with bunx/npx."
    },
    "reddit-search": {
      "command": "uvx",
      "args": ["reddit-no-auth-mcp-server"],
      "disabled": false,
      "_comment": "@v3 Reddit MCP keyless (eliasbiondo/reddit-mcp-server) — 6 tools: search, search_subreddit, get_post, get_subreddit_posts, get_user, get_user_posts. Zero config, no auth."
    },
    "markitdown-mcp": {
      "command": "uvx",
      "args": ["markitdown-mcp"],
      "disabled": false,
      "_comment": "@productivity-mvp Microsoft markitdown — convert office files (PDF/DOCX/XLSX/PPTX/TXT/HTML) to markdown LLM-ready. MIT license, keyless, Context7 Bench 90.05."
    },

    "financial-modeling-prep-mcp": {
      "command": "uvx",
      "args": ["--from", "git+https://github.com/imbenrabi/Financial-Modeling-Prep-MCP-Server", "server"],
      "disabled": false,
      "env": {
        "FMP_API_KEY": "${FMP_API_KEY}"
      },
      "_comment": "@trader-agent-v1 Financial Modeling Prep MCP — 253+ tools covering stocks, ETF, options, futures, crypto, forex, commodities, macro, fundamentals, technicals, news, SEC, analyst estimates. PRIMARY cornerstone."
    },
    "helium-mcp": {
      "url": "https://heliumtrades.com/mcp",
      "type": "streamable-http",
      "disabled": false,
      "_comment": "@trader-agent-v1 Helium MCP — news intelligence + bias scoring + live market data + AI options pricing. 9 tools, 5000+ sources, free tier. PRIMARY."
    },
    "mcp-fredapi": {
      "command": "uvx",
      "args": ["--from", "mcp-fredapi", "--with", "httpx", "mcp", "run", "server.py"],
      "disabled": false,
      "env": {
        "FRED_API_KEY": "${FRED_API_KEY}"
      },
      "_comment": "@trader-agent-v1 FRED API MCP (Jaldekoa/mcp-fredapi) — macroeconomic data (rates, GDP, inflation, NFP). Gold standard macro. PRIMARY."
    },
    "financekit-mcp": {
      "command": "uvx",
      "args": ["--from", "financekit-mcp", "financekit"],
      "disabled": false,
      "_comment": "@trader-agent-v1 FinanceKit MCP — stock quotes, technical analysis (RSI, MACD, Bollinger, SMA/EMA), crypto data, portfolio analysis. 12 tools, no API key. SECONDARY."
    },
    "alpaca-mcp": {
      "command": "python3",
      "args": ["/home/fulvio/coding/aria/scripts/mcp-servers/alpaca-mcp-server/mcp_server.py"],
      "disabled": false,
      "env": {
        "ALPACA_API_KEY": "${ALPACA_API_KEY}",
        "ALPACA_API_SECRET": "${ALPACA_API_SECRET}",
        "ALPACA_BASE_URL": "https://paper-api.alpaca.markets",
        "POLYGON_API_KEY": "${POLYGON_API_KEY}"
      },
      "_comment": "@trader-agent-v1 Alpaca MCP (dtony47/alpaca-mcp-server) — market data + paper trading execution (no real money). 22 tools. EXECUTION-ONLY READ."
    }
  }
}
