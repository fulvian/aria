#!/usr/bin/env bash
# ARIA launcher — guarantees isolation from global KiloCode installation
# Built from: docs/foundation/aria_foundation_blueprint.md §4.3

set -euo pipefail

# === ARIA paths ===
ARIA_HOME="${ARIA_HOME:-/home/fulvio/coding/aria}"
export ARIA_HOME
ARIA_KILO_HOME="${ARIA_KILO_HOME:-$ARIA_HOME/.aria/kilo-home}"
export ARIA_KILO_HOME

# Force fully isolated Kilo runtime under ARIA only.
export HOME="$ARIA_KILO_HOME"
export XDG_CONFIG_HOME="$HOME/.config"
export XDG_DATA_HOME="$HOME/.local/share"
export XDG_STATE_HOME="$HOME/.local/state"
export XDG_CACHE_HOME="$HOME/.cache"

# === KiloCode isolation (P1: Isolation First) ===
export KILOCODE_CONFIG_DIR="$ARIA_HOME/.aria/kilocode"
export KILOCODE_STATE_DIR="$ARIA_HOME/.aria/kilocode/sessions"
export KILOCODE_HOME="$KILOCODE_CONFIG_DIR"
export KILO_DISABLE_EXTERNAL_SKILLS="${KILO_DISABLE_EXTERNAL_SKILLS:-true}"

# === ARIA memory-recovery: deterministic per-process session id ===
if [[ -z "${ARIA_SESSION_ID:-}" ]]; then
    if command -v uuidgen >/dev/null 2>&1; then
        ARIA_SESSION_ID="$(uuidgen)"
    else
        ARIA_SESSION_ID="$(python3 -c 'import uuid;print(uuid.uuid4())')"
    fi
fi
export ARIA_SESSION_ID
export ARIA_MEMORY_STRICT_SESSION=1

# === ARIA runtime paths ===
export ARIA_RUNTIME="$ARIA_HOME/.aria/runtime"
export ARIA_CREDENTIALS="$ARIA_HOME/.aria/credentials"

# === Load .env if present (non-secrets only; secrets via SOPS) ===
if [[ -f "$ARIA_HOME/.env" ]]; then
    set -a
    source "$ARIA_HOME/.env"
    set +a
fi

# === Pre-flight checks ===
check_prerequisites() {
    local missing=0

    if [[ ! -d "$KILOCODE_CONFIG_DIR" ]]; then
        echo "ERR: KiloCode config directory missing: $KILOCODE_CONFIG_DIR" >&2
        missing=1
    fi

    if [[ ! -f "$KILOCODE_CONFIG_DIR/kilo.json" ]]; then
        echo "ERR: kilo.json missing in: $KILOCODE_CONFIG_DIR" >&2
        missing=1
    fi

    if [[ ! -d "$ARIA_RUNTIME" ]]; then
        echo "ERR: ARIA runtime directory missing: $ARIA_RUNTIME" >&2
        missing=1
    fi

    if [[ ! -d "$KILOCODE_CONFIG_DIR/agents" ]]; then
        echo "ERR: ARIA agents directory missing: $KILOCODE_CONFIG_DIR/agents" >&2
        missing=1
    fi

    if [[ ! -d "$KILOCODE_CONFIG_DIR/skills" ]]; then
        echo "ERR: ARIA skills directory missing: $KILOCODE_CONFIG_DIR/skills" >&2
        missing=1
    fi

    if [[ $missing -eq 1 ]]; then
        echo "Hint: Run ./scripts/bootstrap.sh to initialize the environment" >&2
        exit 1
    fi

    # Check Python environment
    if [[ -f "$ARIA_HOME/.venv/bin/python" ]]; then
        export PATH="$ARIA_HOME/.venv/bin:$PATH"
    fi
}

prepare_isolated_runtime() {
    mkdir -p "$HOME" "$XDG_CONFIG_HOME" "$XDG_DATA_HOME" "$XDG_STATE_HOME" "$XDG_CACHE_HOME"
    mkdir -p "$HOME/.kilo/agents" "$HOME/.kilo/skills"
    mkdir -p "$XDG_CONFIG_HOME/kilo"

    # Keep isolated HOME-level Kilo paths synchronized from ARIA source-of-truth.
    cp -a "$KILOCODE_CONFIG_DIR/agents/." "$HOME/.kilo/agents/"
    cp -a "$KILOCODE_CONFIG_DIR/skills/." "$HOME/.kilo/skills/"

    # Migrate legacy ARIA MCP config into modern Kilo `mcp` schema.
    python3 - <<'PY'
import json
import os
from pathlib import Path

legacy_path = Path(os.environ["KILOCODE_CONFIG_DIR"]) / "mcp.json"
modern_path = Path(os.environ["XDG_CONFIG_HOME"]) / "kilo" / "kilo.jsonc"

legacy = {}
if legacy_path.exists():
    with legacy_path.open("r", encoding="utf-8") as fp:
        legacy = json.load(fp)

modern = {}
if modern_path.exists():
    try:
        with modern_path.open("r", encoding="utf-8") as fp:
            modern = json.load(fp)
    except json.JSONDecodeError:
        # Keep boot resilient even if user manually introduced JSONC comments.
        modern = {}

servers = legacy.get("mcpServers", {})
existing_mcp = modern.get("mcp", {})
mcp = {}
if isinstance(existing_mcp, dict):
    mcp.update(existing_mcp)

# Drop deprecated alias keys when canonical servers are present.
for deprecated_key in ("tavily", "firecrawl", "brave"):
    mcp.pop(deprecated_key, None)

# Drop deprecated/removed ARIA profiles from isolated runtime.
for removed_key in ("google_workspace_readonly", "playwright"):
    mcp.pop(removed_key, None)

for name, cfg in servers.items():
    command = []
    base_cmd = cfg.get("command")
    if isinstance(base_cmd, str) and base_cmd:
        command.append(base_cmd)
    args = cfg.get("args", [])
    if isinstance(args, list):
        command.extend(str(arg) for arg in args)

    if not command:
        continue

    env = cfg.get("env", {})
    migrated_env = {}
    if isinstance(env, dict):
        for key, value in env.items():
            # Preserve placeholders (e.g. ${TOKEN}) to avoid writing secrets to disk.
            migrated_env[str(key)] = str(value)

    entry = {
        "type": "local",
        "command": command,
        "enabled": not bool(cfg.get("disabled", False)),
    }
    timeout = cfg.get("timeout")
    if isinstance(timeout, int) and timeout > 0:
        entry["timeout"] = timeout
    if migrated_env:
        entry["environment"] = migrated_env

    mcp[name] = entry

modern["mcp"] = mcp
modern.setdefault("$schema", "https://kilo.ai/schema/config.json")

with modern_path.open("w", encoding="utf-8") as fp:
    json.dump(modern, fp, indent=2)
    fp.write("\n")
PY
}

# === Kilo CLI compatibility ===
declare -a KILO_CLI_CMD=()
KILO_CLI_MODE=""

resolve_kilo_cli() {
    if command -v kilo >/dev/null 2>&1; then
        KILO_CLI_CMD=("kilo")
    elif command -v npx >/dev/null 2>&1; then
        KILO_CLI_CMD=("npx" "--yes" "kilocode")
    else
        echo "ERR: Neither 'kilo' nor 'npx' is available in PATH" >&2
        exit 1
    fi

    local help_text
    if ! help_text="$(${KILO_CLI_CMD[@]} --help 2>&1)"; then
        echo "ERR: Unable to execute Kilo CLI. Check your installation." >&2
        exit 1
    fi

    if [[ "$help_text" == *"kilo [project]"* ]] || [[ "$help_text" == *"run [message..]"* ]]; then
        KILO_CLI_MODE="modern"
        return
    fi

    if [[ "$help_text" == *"chat"* ]]; then
        KILO_CLI_MODE="legacy"
        return
    fi

    echo "ERR: Unsupported Kilo CLI syntax detected. Update bin/aria launcher." >&2
    exit 1
}

has_agent_arg() {
    local arg=""
    for arg in "$@"; do
        if [[ "$arg" == "--agent" ]]; then
            return 0
        fi
    done
    return 1
}

# === Subcommands ===
show_help() {
    cat <<'EOF'
ARIA — Autonomous Reasoning & Intelligent Assistant

Usage: aria <command> [options]

Commands:
  repl          Start ARIA interactive REPL (default)
  run <prompt>  Execute a single prompt and exit
  mode <name>   Set active mode (from .aria/kilocode/modes/)
  schedule      Run scheduler daemon
  gateway       Run gateway daemon (Telegram)
  memory        Run memory MCP server
  creds         Manage credentials (reload, rotate, status)
  backup        Run backup script
  --help, -h    Show this help message

Environment:
  ARIA_HOME          ARIA root directory
  ARIA_RUNTIME       Runtime data directory
  ARIA_CREDENTIALS   Credentials directory
  ARIA_LOG_LEVEL     Log level (DEBUG|INFO|WARN|ERROR)
  ARIA_TIMEZONE      Timezone (default: Europe/Rome)
  ARIA_QUIET_HOURS   Quiet hours (no proactive notifications)

Examples:
  aria repl                      # Start interactive session
  aria run "Search for X"        # Execute single command
  aria schedule --daemon         # Run scheduler
  aria creds status              # Show credential status

For documentation, see: docs/foundation/aria_foundation_blueprint.md
EOF
}

# === Main dispatch ===
main() {
    check_prerequisites
    prepare_isolated_runtime
    resolve_kilo_cli

    local subcommand="${1:-repl}"
    shift || true

    case "$subcommand" in
        repl)
            if [[ "${1:-}" == "--help" || "${1:-}" == "-h" || "${1:-}" == "help" ]]; then
                show_help
                return 0
            fi
            if [[ "$KILO_CLI_MODE" == "modern" ]]; then
                if has_agent_arg "$@"; then
                    exec "${KILO_CLI_CMD[@]}" "$ARIA_HOME" "$@"
                fi
                exec "${KILO_CLI_CMD[@]}" "$ARIA_HOME" --agent "${ARIA_DEFAULT_AGENT:-aria-conductor}" "$@"
            fi
            exec "${KILO_CLI_CMD[@]}" chat "$@"
            ;;
        run)
            if [[ "${1:-}" == "--help" || "${1:-}" == "-h" || "${1:-}" == "help" ]]; then
                show_help
                return 0
            fi
            if [[ "$KILO_CLI_MODE" == "modern" ]]; then
                if has_agent_arg "$@"; then
                    exec "${KILO_CLI_CMD[@]}" run --auto "$@"
                fi
                exec "${KILO_CLI_CMD[@]}" run --agent "${ARIA_DEFAULT_AGENT:-aria-conductor}" --auto "$@"
            fi
            exec "${KILO_CLI_CMD[@]}" chat --auto "$@"
            ;;
        mode)
            if [[ "${1:-}" == "--help" || "${1:-}" == "-h" || "${1:-}" == "help" ]]; then
                show_help
                return 0
            fi
            if [[ "$KILO_CLI_MODE" == "modern" ]]; then
                exec "${KILO_CLI_CMD[@]}" "$ARIA_HOME" --agent "$@"
            fi
            exec "${KILO_CLI_CMD[@]}" chat --mode "$@"
            ;;
        schedule)
            exec python -m aria.scheduler.daemon "$@"
            ;;
        gateway)
            exec python -m aria.gateway.daemon "$@"
            ;;
        memory)
            exec python -m aria.memory.mcp_server "$@"
            ;;
        creds)
            exec python -m aria.credentials "$@"
            ;;
        backup)
            exec "$ARIA_HOME/scripts/backup.sh" "$@"
            ;;
        --help|-h|help)
            show_help
            ;;
        *)
            echo "Unknown command: $subcommand" >&2
            echo "Run 'aria --help' for usage information" >&2
            exit 2
            ;;
    esac
}

main "$@"
