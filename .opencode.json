{
  "$schema": "./opencode-schema.json",
  "aria": {
    "enabled": true,
    "routing": {
      "defaultAgency": "development",
      "confidenceThreshold": 0.7,
      "enableFallback": true
    },
    "agencies": {
      "development": {
        "enabled": true,
        "coderBridge": true
      }
    },
    "skills": {
      "codeReview": true,
      "tdd": true,
      "debugging": true
    },
    "scheduler": {
      "maxConcurrentTasks": 3,
      "defaultPriority": 50
    },
    "guardrails": {
      "allowProactive": false,
      "maxDailyActions": 10
    }
  },
  "commands": {
    "/plan": {
      "description": "Force planner to generate execution plan",
      "agent": "orchestrator"
    },
    "/decide-agent": {
      "description": "Invoke decision engine for query analysis",
      "agent": "orchestrator"
    },
    "/debug-plan": {
      "description": "Post-mortem deliberative analysis",
      "agent": "orchestrator"
    },
    "/review-response": {
      "description": "Review output candidate with reviewer",
      "agent": "orchestrator"
    }
  },
  "lsp": {
    "gopls": {
      "command": "gopls"
    }
  }
}
