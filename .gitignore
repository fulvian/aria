venv.bak/

# IDE
.idea/
.vscode/
*.swp
*.swo
*~

# OS
.DS_Store
Thumbs.db

# ARIA-specific runtime state (NEVER commit)
.aria/runtime/
.aria/kilocode/sessions/
.aria/credentials/**
!.aria/credentials/.sops.yaml
!.aria/credentials/secrets/
!.aria/credentials/secrets/*.enc.yaml
*.db
*.db-journal
*.db-wal
*.db-shm

# SOPS files (private keys outside repo, encrypted files stay)
# .sops.yaml is committed (config only, no secrets)
/.sops.yaml

# Logs
*.log
logs/

# Temporary files
tmp/
*.tmp

# Backups
*.backup
*.bak
*.age
.age.pub

# memory recovery backups
.aria/runtime/memory/episodic.db.bak.*
.aria/runtime/memory/episodic.db-wal.bak.*
.aria/runtime/memory/episodic.db-shm.bak.*

# Node (KiloCode manages this but we don't want node_modules in git)
node_modules/

# Lock files - keep uv.lock but not package-lock.json for our package
# uv.lock is committed (reproducible builds)
# package-lock.json is generated by npm, can be ignored for KiloCode CLI
